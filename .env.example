# Slack App credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# AI Provider API keys
GOOGLE_GENERATIVE_AI_API_KEY=...
OPENAI_API_KEY=...
NEBIUS_API_KEY=...

# Override default model string per provider (optional)
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o
# NEBIUS_MODEL=nvidia/nemotron-3-super-120b-a12b

# Ollama (local) provider — no API key needed
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Which provider to use by default: gemini | openai | nebius | ollama
DEFAULT_PROVIDER=gemini

# Bot display name used in persona system prompts (optional)
# IRISBOT_NAME=IrisBot

# App config
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
